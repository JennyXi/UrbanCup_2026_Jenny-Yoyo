{
  "experiment_id": "formal_nine_zone_four_mode_baseline_v2",
  "description": "No-policy nine-zone Agent transport baseline using walking, bus, metro and ride_hailing.",
  "total_agents": 50,
  "seed": 47,
  "week_start": "2026-07-06",
  "enabled_modes": ["walk", "bus", "metro", "ride_hailing"],
  "policy": "P0_no_policy",
  "experiment_condition": "P0_baseline",
  "selected_days": {
    "workday": "2026-07-07",
    "rest_day": "2026-07-11"
  },
  "weather_scenarios": {
    "W0": {
      "weather_type": "normal",
      "windows_by_day_type": {"workday": [], "rest_day": []}
    },
    "W1": {
      "weather_type": "extreme_heat",
      "windows_by_day_type": {
        "workday": [["11:00", "18:00"]],
        "rest_day": [["11:00", "18:00"]]
      }
    },
    "W2": {
      "weather_type": "heavy_rain",
      "windows_by_day_type": {
        "workday": [["07:00", "10:00"], ["17:00", "20:00"]],
        "rest_day": [["10:00", "14:00"]]
      }
    }
  },
  "activity_behavior_changes_enabled": false,
  "mode_choice": {
