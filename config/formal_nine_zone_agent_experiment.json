      "rest_day": {"Z1": 2, "Z2": 2, "Z3": 2, "Z4": 1, "Z5": 1, "Z6": 1, "Z7": 2, "Z8": 1, "Z9": 1}
    },
    "maximum_vehicle_wait_min": 20.0,
    "non_capacity_success_probability": 1.0,
    "vehicle_id_prefix": "N9RH"
  },
