    "value_of_time_yuan_per_hour": {"18-39": 45.0, "40-59": 38.0, "60+": 25.0},
    "age_mode_constant": {
      "18-39": {"walk": 1.0, "bus": 0.0, "metro": 0.0, "ride_hailing": 0.3},
      "40-59": {"walk": 0.0, "bus": 0.5, "metro": 0.0, "ride_hailing": 0.5},
      "60+": {"walk": -1.5, "bus": 1.0, "metro": 0.0, "ride_hailing": 0.3}
    },
    "weather_preference": {
      "normal": {"walk": 0.0, "bus": 0.0, "metro": 0.0, "ride_hailing": 0.0},
      "extreme_heat": {"walk": -0.75, "bus": -0.25, "metro": 0.0, "ride_hailing": 0.15},
      "heavy_rain": {"walk": -1.5, "bus": -0.6, "metro": 0.0, "ride_hailing": 0.25}
    },
    "weather_exposure_disutility": {
      "enabled": true,
      "utility_penalty_per_outdoor_minute": {
        "normal": 0.0,
        "extreme_heat": 0.025,
        "heavy_rain": 0.035
      },
      "age_vulnerability_weight": {
        "18-39": 1.0,
        "40-59": 1.2,
        "60+": 1.6
      },
      "medical_need_level_weight": {
        "low": 1.0,
        "standard": 1.2,
        "high": 1.5
      }
    },
    "conditional_fare_sensitivity": {
      "enabled": true,
      "necessary_purposes": ["work", "medical"],
      "weather_types": ["extreme_heat", "heavy_rain"],
      "elder_exposed_necessary_multiplier": 0.9
    },
    "age_transfer_burden": {
      "enabled": true,
      "minutes_per_transfer_by_age": {
        "18-39": 0.0,
        "40-59": 0.0,
        "60+": 3.0
      }
    }
  },
  "activity_time_linkage": {
    "reliability_buffer_min": {
      "walk": 3.0,
      "bus": 10.0,
      "metro": 5.0,
      "ride_hailing": 8.0
    },
    "maximum_early_departure_min": 120.0,
    "on_time_tolerance_min": 5.0,
    "maximum_acceptable_lateness_min": 30.0,
    "maximum_commute_time_min": 120.0,
    "lateness_penalty_yuan_per_min": 1.0,
    "departure_choice_iterations": 2,
    "interpretation": "Scenario assumptions. Fixed activity start times are preserved; chosen expected door-to-door time and reliability buffer determine departure."
  },
  "departure_time_concentration": {
    "enabled": false,
    "compression_factor": 1.0,
    "center_time_by_purpose": {
      "work": "08:00",
      "medical": "09:00"
    }
  },
  "road_feedback": {
    "iterations": 1,
