    "maximum_attempts_after_primary": 1,
    "preserve_consumed_wait": true,
    "remove_failed_mode": true
  },
  "bus_system": {
    "vehicle_capacity_passengers": 50.0,
    "capacity_constraint_enabled": false,
    "scheduled_routes_in_both_directions": true
  },
  "behavioral_scope_assumptions": {
    "ride_hailing_rechoice_after_request": false,
    "ride_hailing_request_accepted_until_maximum_wait_or_failure": true,
    "bus_boarding_is_guaranteed": true,
    "metro_boarding_is_guaranteed": true,
    "interpretation": "After requesting ride-hailing, an Agent accepts the realized pickup ETA unless the configured wait limit or dispatch failure triggers fallback. Public transport crowding and denied boarding are outside this mechanism experiment."
  },
  "scope_notes": [
    "Metro is a continuous cross-zone trunk network. Only Z1/Z2/Z3/Z7 have sufficient station density for modeled intrazonal metro trips.",
    "The same Agents, activities and planned legs are paired across W0/W1/W2.",
    "Weather-related activity cancellation and remote work are disabled in this transport baseline.",
    "The selected elderly mode constant, exposure weight, conditional fare-sensitivity multiplier and transfer burden are stable scenario assumptions from the experiment branch, not observed Shanghai estimates.",
    "All numeric parameters are scenario assumptions for mechanism testing, not calibrated Shanghai forecasts."
  ]
