    "representative_corridor_id": "nine_zone_representative",
    "representative_direction": "all",
    "bus_vehicle_pcu": 2.0,
    "ride_hailing_vehicle_pcu": 1.0,
    "agent_trip_weight": 1.0,
    "directional_divisor": 2.0,
    "interpretation": "Citywide representative shared-road feedback. This first baseline is not a link-level assignment."
  },
  "ride_hailing_fleet": {
    "initial_vehicles_by_day_type": {
